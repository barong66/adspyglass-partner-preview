<% content_for :seo_title, "Partner Program for Ad Networks" %>
<% content_for :seo_description, "Two ways for ad networks and DSPs to access AdSpyglass publisher traffic — buy on Traforama, or pre-integrate your network. $1,000 deposit + 5% rev share for pre-integration." %>

<!-- Hero -->
