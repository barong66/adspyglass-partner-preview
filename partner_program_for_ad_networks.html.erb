        Partner Program for Ad Networks
      </h1>
      <p class="mb-4 fs-lg mx-auto w-100 w-lg-50">
        Get access to traffic from 500+ AdSpyglass publishers.
      </p>
      <div class="d-flex justify-content-center">
        <a href="#paths" class="btn btn-lg btn-primary">
          Get started
          <i class="bi bi-arrow-down ms-2"></i>
        </a>
      </div>
    </div>
    <%= image_tag 'asg/partner-program/img1.png', alt: 'Illustration', class: 'd-md-block d-none', loading: 'lazy' %>
    <%= image_tag 'asg/partner-program/img1-mob.png', alt: 'Illustration', class: 'd-md-none d-block mx-auto', loading: 'lazy' %>
  </div>
</section>

