<!-- Two ways to work with us -->
<section id="paths" class="py-5 min-vh-100 d-flex align-items-center">
  <div class="my-lg-5 my-md-4 my-3 container">
    <div class="mb-lg-5 mb-4 pb-lg-0 pb-md-2 mx-auto text-center" style="max-width: 53.5rem;">
      <h2 class="mb-md-4 mb-3 h1">
        Two ways to work with us
      </h2>
      <p class="mb-0 fs-lg">
        Pick the path that fits your stack. Most networks start with Traforama &mdash; it's the fastest way to get live.
      </p>
    </div>

    <div class="row row-cols-1 row-cols-lg-2 g-4">

      <!-- Option A — Traforama (recommended) -->
      <div class="col">
        <div class="d-flex flex-column p-4 p-lg-5 bg-white rounded-5 h-100">
          <div class="mb-3">
            <span class="badge bg-primary fs-sm fw-semibold text-uppercase">Recommended &mdash; start here</span>
          </div>
          <h3 class="fs-3 mb-2">Buy traffic via Traforama</h3>
          <p class="fs-18 mb-4">
            Our open marketplace. Sign up, fund your account, launch a campaign &mdash; you pick exactly which traffic to buy.
          </p>

          <h5 class="fs-sm fw-bold text-uppercase text-success mb-3 d-inline-flex align-items-center gap-2" style="letter-spacing: .08em;"><i class="bi bi-plus-circle-fill"></i>Pros</h5>
          <div class="d-flex align-items-start fs-18 mb-2">
            <i class="bi bi-check2 me-3 fs-5 text-primary"></i>
            <span><strong>No integration required</strong> &mdash; start buying in minutes</span>
          </div>
          <div class="d-flex align-items-start fs-18 mb-2">
            <i class="bi bi-check2 me-3 fs-5 text-primary"></i>
            <span><strong>Pick exactly the traffic you want</strong> by site, format, geo</span>
          </div>
          <div class="d-flex align-items-start fs-18 mb-2">
            <i class="bi bi-check2 me-3 fs-5 text-primary"></i>
            <span><strong>Pay only for what you buy</strong> &mdash; no AdSpyglass fees on top</span>
          </div>
          <div class="d-flex align-items-start fs-18 mb-2">
            <i class="bi bi-check2 me-3 fs-5 text-primary"></i>
            <span><strong>XML/JSON feeds &amp; OpenRTB 2.5</strong> supported</span>
          </div>
          <div class="d-flex align-items-start fs-18 mb-4">
            <i class="bi bi-check2 me-3 fs-5 text-primary"></i>
            <span><strong>One contract, one payment</strong>, full transparency</span>
          </div>

          <h5 class="fs-sm fw-bold text-uppercase mb-3 d-inline-flex align-items-center gap-2" style="color:#968C8A; letter-spacing: .08em;"><i class="bi bi-dash-circle-fill"></i>Cons</h5>
          <div class="d-flex align-items-start fs-18 mb-4">
            <i class="bi bi-dash-lg me-3 fs-5" style="color:#968C8A;"></i>
            <span><strong>No direct relationship with publishers</strong> &mdash; you buy through our marketplace</span>
          </div>

          <div class="mt-auto">
            <%= link_to "Register at Traforama", traforama_registration_url, class: "btn btn-primary w-100", target: "_blank" %>
          </div>
        </div>
      </div>

      <!-- Option B — Pre-integrated network -->
      <div class="col">
        <div class="d-flex flex-column p-4 p-lg-5 bg-white rounded-5 h-100">
          <h3 class="fs-3 mb-2 mt-md-4 pt-md-1">Pre-integrate your network</h3>
          <p class="fs-18 mb-4">
            For networks that want to be listed in our pre-integrated catalog so publishers can connect you directly. Requires API integration on your side.
          </p>

          <h5 class="fs-sm fw-bold text-uppercase text-success mb-3 d-inline-flex align-items-center gap-2" style="letter-spacing: .08em;"><i class="bi bi-plus-circle-fill"></i>Pros</h5>
          <div class="d-flex align-items-start fs-18 mb-2">
            <i class="bi bi-check2 me-3 fs-5 text-primary"></i>
            <span><strong>Direct relationship</strong> with each publisher who connects you</span>
          </div>
          <div class="d-flex align-items-start fs-18 mb-2">
            <i class="bi bi-check2 me-3 fs-5 text-primary"></i>
            <span><strong>Listed in our catalog</strong> visible to all AdSpyglass publishers</span>
          </div>
          <div class="d-flex align-items-start fs-18 mb-4">
            <i class="bi bi-check2 me-3 fs-5 text-primary"></i>
            <span><strong>Real-time stats</strong> pulled from your API</span>
          </div>

          <h5 class="fs-sm fw-bold text-uppercase mb-3 d-inline-flex align-items-center gap-2" style="color:#968C8A; letter-spacing: .08em;"><i class="bi bi-dash-circle-fill"></i>Cons</h5>
          <div class="d-flex align-items-start fs-18 mb-2">
            <i class="bi bi-dash-lg me-3 fs-5" style="color:#968C8A;"></i>
            <span><strong>Integration alone doesn't deliver traffic</strong> &mdash; each publisher still has to register their own account in your network and add it to their creatives</span>
          </div>
          <div class="d-flex align-items-start fs-18 mb-2">
            <i class="bi bi-dash-lg me-3 fs-5" style="color:#968C8A;"></i>
            <span><strong>$1,000 deposit + 5% rev share</strong> to AdSpyglass</span>
          </div>
          <div class="d-flex align-items-start fs-18 mb-4">
            <i class="bi bi-dash-lg me-3 fs-5" style="color:#968C8A;"></i>
            <span><strong>~2 weeks API integration</strong> + ongoing maintenance on your side</span>
          </div>

          <div class="mt-auto">
            <a href="#apply" class="btn btn-dark w-100">Apply for pre-integration</a>
          </div>
        </div>
      </div>
    </div>
    </div>
</section>

<!-- Pre-integration: who it's for -->
<section class="py-5 bg-white min-vh-100 d-flex align-items-center">
  <div class="my-lg-5 my-md-4 my-3 container">
    <div class="mb-lg-5 mb-4 pb-lg-0 pb-md-2 mx-auto text-center" style="max-width: 53.5rem;">
      <h2 class="mb-md-4 mb-3 h1">
        Pre-integration: who it's for
      </h2>
      <p class="mb-0 fs-lg">
        Before you spend two weeks on integration, make sure the program matches your setup. Three quick checks on each side.
      </p>
    </div>

    <div class="row row-cols-1 row-cols-md-2 g-4 mx-auto" style="max-width: 78.5rem;">
      <%# Fit column %>
      <div class="col">
        <div class="d-flex flex-column p-4 p-lg-5 bg-white rounded-5 h-100">
          <div class="d-flex align-items-center gap-3 mb-4">
            <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary text-white" style="width: 3rem; height: 3rem;">
              <i class="bi bi-check2 fs-3"></i>
            </span>
            <h5 class="fs-2 m-0 text-primary">You're a fit if</h5>
          </div>

          <div class="d-flex gap-3 mb-4">
            <i class="bi bi-broadcast text-primary fs-3 flex-shrink-0"></i>
            <div>
              <h6 class="fs-5 mb-1">Ad network or DSP</h6>
              <p class="m-0 fs-sm">You operate an ad network or DSP and buy publisher traffic to run your demand.</p>
            </div>
          </div>

          <div class="d-flex gap-3 mb-4">
            <i class="bi bi-code-slash text-primary fs-3 flex-shrink-0"></i>
            <div>
              <h6 class="fs-5 mb-1">API ready</h6>
              <p class="m-0 fs-sm">You expose (or can build) REST endpoints for zones, ad code, and traffic statistics.</p>
            </div>
          </div>

          <div class="d-flex gap-3 mb-0">
            <i class="bi bi-cash-stack text-primary fs-3 flex-shrink-0"></i>
            <div>
              <h6 class="fs-5 mb-1">Comfortable with the terms</h6>
              <p class="m-0 fs-sm">$1,000 onboarding deposit and 5% revenue share fit your business model.</p>
            </div>
          </div>
        </div>
      </div>

      <%# Not-a-fit column %>
      <div class="col">
        <div class="d-flex flex-column p-4 p-lg-5 bg-white rounded-5 h-100">
          <div class="d-flex align-items-center gap-3 mb-4">
            <span class="d-inline-flex align-items-center justify-content-center rounded-circle text-white" style="width: 3rem; height: 3rem; background-color:#968C8A;">
              <i class="bi bi-x fs-2"></i>
            </span>
            <h5 class="fs-2 m-0" style="color:#968C8A;">You're not a fit if</h5>
          </div>

          <div class="d-flex gap-3 mb-4">
            <i class="bi bi-plug fs-3 flex-shrink-0" style="color:#968C8A;"></i>
            <div>
              <h6 class="fs-5 mb-1">No API</h6>
              <p class="m-0 fs-sm">You don't expose endpoints for zones, ad code, or statistics &mdash; and don't plan to build them.</p>
            </div>
          </div>

          <div class="d-flex gap-3 mb-4">
            <i class="bi bi-piggy-bank fs-3 flex-shrink-0" style="color:#968C8A;"></i>
            <div>
              <h6 class="fs-5 mb-1">Can't commit the deposit</h6>
              <p class="m-0 fs-sm">$1,000 upfront isn't workable for your business right now.</p>
            </div>
          </div>

          <div class="d-flex gap-3 mb-0">
            <i class="bi bi-bullseye fs-3 flex-shrink-0" style="color:#968C8A;"></i>
            <div>
              <h6 class="fs-5 mb-1">Narrow coverage</h6>
              <p class="m-0 fs-sm">Your offers can only fill a small slice of routed traffic &mdash; integration won't pay for itself.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%# Closing callout for the unsure %>
    <div class="mt-4 mt-lg-5 mx-auto" style="max-width: 78.5rem;">
      <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 p-4 p-lg-4 bg-white rounded-5">
        <div>
          <h6 class="fs-5 mb-1">Not sure where you land?</h6>
          <p class="m-0 fs-sm text-body-secondary">Apply anyway &mdash; or start with Traforama and switch later.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
          <a href="#apply" class="btn btn-dark">Apply for pre-integration</a>
          <%= link_to "Start with Traforama", traforama_registration_url, class: "btn btn-outline-dark", target: "_blank" %>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Terms -->
<section id="terms" class="py-5 min-vh-100 d-flex align-items-center">
  <div class="my-lg-5 my-md-4 my-3 container">
    <div class="mb-lg-5 mb-4 pb-lg-0 pb-md-2 mx-auto text-center" style="max-width: 53.5rem;">
      <h2 class="mb-md-4 mb-3 h1">
        Partnership terms
      </h2>
      <p class="mb-0 fs-lg">
        The same terms apply to every pre-integrated network &mdash; whether you applied directly or were referred by a publisher.
      </p>
    </div>

    <div class="row g-4 mx-auto" style="max-width: 78.5rem;">
      <div class="col-lg-7">
        <div class="bg-white rounded-5 p-4 p-lg-5 h-100">
          <div class="d-flex flex-column flex-md-row align-items-md-center py-3 border-bottom">
            <div class="fw-semibold w-100 w-md-50 mb-2 mb-md-0">Onboarding deposit</div>
            <div class="w-100 w-md-50 fs-18">
              <span class="text-primary fs-3 fw-bold">$1,000</span> &mdash; paid once at registration, before integration starts
            </div>
          </div>
          <div class="d-flex flex-column flex-md-row align-items-md-center py-3 border-bottom">
            <div class="fw-semibold w-100 w-md-50 mb-2 mb-md-0">Revenue share</div>
            <div class="w-100 w-md-50 fs-18">
              <span class="text-primary fs-3 fw-bold">5%</span> of revenue generated by routed traffic
            </div>
          </div>
          <div class="d-flex flex-column flex-md-row align-items-md-center py-3 border-bottom">
            <div class="fw-semibold w-100 w-md-50 mb-2 mb-md-0">How the deposit works</div>
            <div class="w-100 w-md-50">5% is deducted from the deposit as traffic accrues. The deposit carries forward &mdash; no monthly minimum.</div>
          </div>
          <div class="d-flex flex-column flex-md-row align-items-md-center py-3 border-bottom">
            <div class="fw-semibold w-100 w-md-50 mb-2 mb-md-0">After the deposit is used up</div>
            <div class="w-100 w-md-50">5% rev share is invoiced monthly based on actual traffic.</div>
          </div>
          <div class="d-flex flex-column flex-md-row align-items-md-center py-3">
            <div class="fw-semibold w-100 w-md-50 mb-2 mb-md-0">Other fees</div>
            <div class="w-100 w-md-50">None. No setup, no platform fee, no monthly minimum.</div>
          </div>
        </div>
      </div>

      <div class="col-lg-5">
        <div class="d-flex flex-column p-4 p-lg-5 bg-dark text-light rounded-5 h-100">
          <h5 class="fs-sm text-uppercase text-primary mb-3">Cost example</h5>
          <div class="d-flex justify-content-between fs-18 mb-2">
            <span>Initial deposit</span>
            <span class="fw-semibold">$1,000</span>
          </div>
          <div class="d-flex justify-content-between fs-18 mb-2">
            <span>Month 1 traffic revenue</span>
            <span class="fw-semibold">$8,000</span>
          </div>
          <div class="d-flex justify-content-between fs-18 mb-3">
            <span>5% &times; $8,000</span>
            <span class="fw-semibold">&minus;$400</span>
          </div>
          <hr class="my-2 text-body-secondary">
          <div class="d-flex justify-content-between fs-18 fw-bold mb-3">
            <span>Deposit balance</span>
            <span class="text-primary">$600</span>
          </div>
          <p class="fs-sm mb-4">
            Once the deposit hits zero, you receive a monthly invoice for 5% of that month's traffic revenue.
          </p>
          <div class="mt-auto">
            <a href="#apply" class="btn btn-primary w-100">Apply now</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- How it works -->
<section class="py-5 bg-dark text-light min-vh-100 d-flex align-items-center">
  <div class="my-lg-5 my-md-4 my-3 container">
    <div class="mb-lg-5 mb-4 pb-lg-0 pb-md-2 mx-auto text-center" style="max-width: 50rem;">
      <h2 class="mb-md-4 mb-3 h1 text-light">
        How to become our pre-integrated partner?
      </h2>
      <p class="mb-0 fs-lg text-light">
        From application to live in the catalog. Roughly two weeks if your API matches our spec.
      </p>
    </div>

    <div class="d-flex flex-column gap-4 mx-auto" style="max-width: 50rem;">
      <div class="d-flex flex-column bg-body rounded-5 p-4 gap-3">
        <h5 class="fs-3 m-0 text-primary">1. Submit your application</h5>
        <p class="m-0">Use the form below. Tell us about your network, traffic volume, and inventory types.</p>
      </div>
      <div class="d-flex flex-column bg-body rounded-5 p-4 gap-3">
        <h5 class="fs-3 m-0 text-primary">2. Terms review &mdash; 2 business days</h5>
        <p class="m-0">Our BD team confirms partnership terms and requests technical contacts on your side.</p>
      </div>
      <div class="d-flex flex-column bg-body rounded-5 p-4 gap-3">
        <h5 class="fs-3 m-0 text-primary">3. Pay the $1,000 deposit</h5>
        <p class="m-0">We send the invoice. Technical integration begins as soon as payment is received.</p>
      </div>
      <div class="d-flex flex-column bg-body rounded-5 p-4 gap-3">
        <h5 class="fs-3 m-0 text-primary">4. Technical integration &mdash; 5 business days</h5>
        <p class="m-0">Our engineers plug into your API: zones, ad code, statistics.</p>
      </div>
      <div class="d-flex flex-column bg-body rounded-5 p-4 gap-3">
        <h5 class="fs-3 m-0 text-primary">5. Go live in the catalog</h5>
        <p class="m-0">Your inventory becomes available to AdSpyglass publishers. First check-in scheduled at week 2 to review performance.</p>
      </div>
    </div>
  </div>
</section>

<!-- Technical requirements -->
<section id="tech" class="py-5 min-vh-100 d-flex align-items-center">
  <div class="my-lg-5 my-md-4 my-3 container">
    <div class="mb-lg-5 mb-4 pb-lg-0 pb-md-2 mx-auto text-center" style="max-width: 53.5rem;">
      <h2 class="mb-md-4 mb-3 h1">
        What we need from your API
      </h2>
      <p class="mb-0 fs-lg">
        Three pieces of data over HTTPS. Path names, parameter names, and response shape are up to you &mdash; what matters is that this information is available.
      </p>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4 mx-auto mb-4" style="max-width: 78.5rem;">
      <div class="col">
        <div class="d-flex flex-column p-4 p-lg-5 bg-white rounded-5 h-100">
          <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary text-white mb-4" style="width: 3rem; height: 3rem;">
            <i class="bi bi-list-ul fs-3"></i>
          </span>
          <div class="fs-sm text-uppercase text-body-secondary mb-1">Step 1</div>
          <h5 class="fs-3 mb-3">Sites &amp; zones list</h5>
          <p class="m-0 mb-3">The publisher sites you operate, each with their ad zones &mdash; zone identifier and a human-readable name per zone.</p>
          <p class="m-0 fs-sm text-body-secondary">We fetch this once on integration and refresh occasionally as your inventory changes.</p>
        </div>
      </div>
      <div class="col">
        <div class="d-flex flex-column p-4 p-lg-5 bg-white rounded-5 h-100">
          <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary text-white mb-4" style="width: 3rem; height: 3rem;">
            <i class="bi bi-code-slash fs-3"></i>
          </span>
          <div class="fs-sm text-uppercase text-body-secondary mb-1">Step 2</div>
          <h5 class="fs-3 mb-3">Ad code for each zone</h5>
          <p class="m-0 mb-3">HTML snippet or URL for serving the zone. Must support <code>{SUB_ID}</code> and <code>{KEYWORDS}</code> macros &mdash; we substitute tracking and targeting values before rendering.</p>
          <p class="m-0 fs-sm text-body-secondary">Macros are critical: without them we lose source attribution and contextual targeting.</p>
        </div>
      </div>
      <div class="col">
        <div class="d-flex flex-column p-4 p-lg-5 bg-white rounded-5 h-100">
          <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary text-white mb-4" style="width: 3rem; height: 3rem;">
            <i class="bi bi-bar-chart-line fs-3"></i>
          </span>
          <div class="fs-sm text-uppercase text-body-secondary mb-1">Step 3</div>
          <h5 class="fs-3 mb-3">Traffic statistics</h5>
          <p class="m-0 mb-3">Impressions, clicks, and revenue per zone &mdash; grouped by date, country, and <code>sub_id</code>. Field names can be anything (<code>shows</code>, <code>views</code>, <code>earnings</code>).</p>
          <p class="m-0 fs-sm text-body-secondary">Pulled nightly to reconcile billing and show publishers their performance.</p>
        </div>
      </div>
    </div>

    <%# Closing callout %>
    <div class="mt-4 mt-lg-5 mx-auto" style="max-width: 78.5rem;">
      <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 p-4 p-lg-4 bg-white rounded-5">
        <div>
          <h6 class="fs-5 mb-1">Full specification &mdash; auth, rate limits, examples</h6>
          <p class="m-0 fs-sm text-body-secondary">Detailed expectations, example payloads, and what we need from a test account.</p>
        </div>
        <%# TODO: replace href with hosted PDF/MD URL once uploaded %>
        <a href="/assets/ad-network-integration-spec.md" target="_blank" class="btn btn-dark text-nowrap">
          <i class="bi bi-download me-2"></i>Download full technical spec
        </a>
      </div>
    </div>

  </div>
</section>

<!-- Application form -->
<section id="apply" class="py-5 bg-white min-vh-100 d-flex align-items-center" data-controller="request-form">
  <div class="container">
    <div class="mb-4 mx-auto text-center" style="max-width: 50rem;">
      <h2 class="mb-md-3 mb-2 display-5">
        Apply for pre-integration
      </h2>
      <p class="m-0 fs-lg">
        Fill in the form and our BD team will get back to you within 2 business days.
      </p>
    </div>

    <div class="mt-4 mx-auto" style="max-width: 56rem;">
      <form id="request-form" name="partner network application" class="request-form bg-white rounded-5 p-4 p-lg-5 needs-validation" novalidate>
        <input type="hidden" name="request[form_name]" value="Partner Network Application" />
        <input type="hidden" id="g-recaptcha-response" name="request[captcha]" />

        <div class="row g-3">
          <div class="col-md-6">
            <label for="network_name" class="form-label fw-semibold mb-1">Network name *</label>
            <input class="form-control" maxlength="256" name="request[network_name]" placeholder="yournetwork" type="text" id="network_name" required />
            <div class="invalid-feedback">Please enter your network name.</div>
          </div>
          <div class="col-md-6">
            <label for="website" class="form-label fw-semibold mb-1">Website *</label>
            <input class="form-control" maxlength="256" name="request[website]" placeholder="https://yournetwork.com" type="url" id="website" required />
            <div class="invalid-feedback">Please enter your website.</div>
          </div>
          <div class="col-md-6">
            <label for="email" class="form-label fw-semibold mb-1">Email *</label>
            <input class="form-control" maxlength="256" name="request[email]" placeholder="bd@yournetwork.com" type="email" id="email" required />
            <div class="invalid-feedback">Please provide a valid email address.</div>
          </div>
          <div class="col-md-6">
            <label for="telegram" class="form-label fw-semibold mb-1">Telegram *</label>
            <input class="form-control" maxlength="256" name="request[telegram]" placeholder="@yourhandle" type="text" id="telegram" required />
            <div class="invalid-feedback">Please provide a Telegram handle.</div>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold mb-1">Stream *</label>
            <div class="d-flex gap-4 pt-1">
              <div class="form-check">
                <input class="form-check-input" type="radio" name="request[stream]" id="stream_mainstream" value="mainstream" required>
                <label class="form-check-label" for="stream_mainstream">Mainstream</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="request[stream]" id="stream_adult" value="adult" required>
                <label class="form-check-label" for="stream_adult">Adult</label>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <label for="api_docs" class="form-label fw-semibold mb-1">API docs URL *</label>
            <input class="form-control" maxlength="500" name="request[api_docs]" placeholder="https://docs.yournetwork.com/api" type="url" id="api_docs" required />
            <div class="invalid-feedback">Please provide a link to your API documentation.</div>
          </div>
          <div class="col-12">
            <label class="form-label fw-semibold mb-1">Ad formats</label>
            <div class="row row-cols-2 row-cols-md-4 g-1">
              <% [
                ['popunders', 'Popunders'],
                ['display_banners', 'Display Banners'],
                ['in_video', 'In-video Ads'],
                ['slider', 'Slider Ads'],
                ['in_page_push', 'In-page Push'],
                ['interstitial', 'Interstitial Ads'],
                ['native_banners', 'Native Banners'],
                ['direct_links', 'Direct Links'],
              ].each do |val, label| %>
                <div class="col">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="request[formats][]" value="<%= val %>" id="fmt_<%= val %>">
                    <label class="form-check-label" for="fmt_<%= val %>"><%= label %></label>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
          <div class="col-12">
            <label for="message" class="form-label fw-semibold mb-1">Anything else?</label>
            <textarea class="form-control" maxlength="2000" name="request[message]" placeholder="Tech contact, integration timeline, special requirements..." rows="2" id="message"></textarea>
          </div>
        </div>

        <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-3 mt-4 pt-2">
          <div class="form-check m-0">
            <input class="form-check-input" type="checkbox" id="terms_accept" name="request[terms_accepted]" required>
            <label class="form-check-label" for="terms_accept">
              I confirm the <a href="#terms" class="fw-semibold text-dark">$1,000 deposit and 5% rev share terms</a>.
            </label>
            <div class="invalid-feedback">You must confirm the terms.</div>
          </div>
          <button class="g-recaptcha btn btn-primary text-nowrap" data-callback="onRecaptchaSuccess" type="button" data-sitekey="<%= ENV['CAPTCHA_KEY'] %>">
            Submit application
          </button>
        </div>
      </form>

      <!-- Success and Failure Messages -->
      <div class="request-form-done text-bg-success text-center p-4 my-4 rounded d-none">
        <div>Thank you! Your application has been received. Our BD team will be in touch within 2 business days.</div>
      </div>
      <div class="request-form-fail text-bg-danger text-center p-4 my-4 rounded d-none">
        <div>Oops! Something went wrong while submitting the form.</div>
      </div>
    </div>
  </div>
</section>

<% content_for :js_scripts do %>
<script src="https://www.google.com/recaptcha/api.js"></script>
<script>
  function onRecaptchaSuccess(token) {
    $('#g-recaptcha-response').val(token);
    $('#request-form').trigger('submit');
  }
</script>
<% end %>

<%= render partial: "asg/common/advertising/advertising_footer" %>
